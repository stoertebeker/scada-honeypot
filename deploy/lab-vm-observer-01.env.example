# Deployment profile: lab-vm-observer-01
# Copy this file to a non-versioned `.env` on the target host and replace
# the marked values before live exposed-research use.

# Identity and presentation
SITE_NAME=Solar Field A
SITE_CODE=lab-vm-observer-01
OPERATOR_NAME=Regional Energy Services
HMI_TITLE=Solar Park Operations
TIMEZONE=Europe/Berlin
ATTACKER_UI_LOCALE=en
ATTACKER_UI_FALLBACK_LOCALE=en

# Plant model
CAPACITY_MW=6.5
INVERTER_BLOCK_COUNT=3
ENABLE_TRACKER=0
DEFAULT_POWER_LIMIT_PCT=100
ALARM_THRESHOLD_LOW_OUTPUT_PCT=35

# Controlled exposed-research ingress
MODBUS_BIND_HOST=0.0.0.0
MODBUS_PORT=1502
HMI_BIND_HOST=0.0.0.0
HMI_PORT=8080
ALLOW_NONLOCAL_BIND=1
EXPOSED_RESEARCH_ENABLED=1
APPROVED_INGRESS_BINDINGS=modbus:0.0.0.0:1502,hmi:0.0.0.0:8080
PUBLIC_INGRESS_MAPPINGS=modbus:502:1502,hmi:80:8080
ENABLE_SERVICE_LOGIN=1

# Event and storage
EVENT_STORE_BACKEND=sqlite
EVENT_STORE_PATH=./data/events.sqlite3
JSONL_ARCHIVE_ENABLED=1
JSONL_ARCHIVE_PATH=./logs/events.jsonl
RUNTIME_STATUS_ENABLED=1
RUNTIME_STATUS_PATH=./logs/runtime-status.json
RUNTIME_STATUS_INTERVAL_SECONDS=5
PCAP_CAPTURE_ENABLED=0
PCAP_CAPTURE_PATH=./pcap/session.pcapng
ALERT_MIN_SEVERITY=medium
OUTBOX_BATCH_SIZE=50
OUTBOX_RETRY_BACKOFF_SECONDS=30
FINDINGS_LOG_PATH=./logs/findings.md

# Exporters
WEBHOOK_EXPORTER_ENABLED=1
# Replace with the real collector URL before internet exposure
WEBHOOK_EXPORTER_URL=https://collector.ops.lab/honeypot-ingest
SMTP_EXPORTER_ENABLED=0
SMTP_HOST="" # e.g. mail.example.net
SMTP_PORT=25
SMTP_FROM="" # e.g. honeypot@example.net
SMTP_TO="" # e.g. alerts@example.net
TELEGRAM_EXPORTER_ENABLED=0
TELEGRAM_BOT_TOKEN="" # e.g. 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID="" # e.g. -1001234567890
APPROVED_EGRESS_TARGETS=webhook:collector.ops.lab:443
APPROVED_EGRESS_RECIPIENTS=webhook:observer-collector-live

# Operational assignments for exposed-research
WATCH_OFFICER_NAME=blue-watch
DUTY_ENGINEER_NAME=ops-duty

# Runtime and logging
LOG_LEVEL=info
TREND_WINDOW_MINUTES=180
ALARM_PAGE_SIZE=25
