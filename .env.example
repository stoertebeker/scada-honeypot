# Identity and presentation
SITE_NAME=Solar Field A
SITE_CODE=site-01
OPERATOR_NAME=Regional Energy Services
HMI_TITLE=Solar Park Operations
TIMEZONE=Europe/Berlin
# Attacker-facing UI locale: `ll` or `ll-RR`, e.g. `en`, `uk`, `en-US`
ATTACKER_UI_LOCALE=en
# Fallback must reference a bundled locale pack
ATTACKER_UI_FALLBACK_LOCALE=en

# Plant model
CAPACITY_MW=6.5
INVERTER_BLOCK_COUNT=3
ENABLE_TRACKER=0
DEFAULT_POWER_LIMIT_PCT=100
ALARM_THRESHOLD_LOW_OUTPUT_PCT=35
WEATHER_PROVIDER=disabled
WEATHER_LATITUDE="" # e.g. 53.5511
WEATHER_LONGITUDE="" # e.g. 9.9937
WEATHER_ELEVATION_M="" # e.g. 15
WEATHER_REFRESH_SECONDS=900
WEATHER_CACHE_TTL_SECONDS=900
WEATHER_REQUEST_TIMEOUT_SECONDS=10

# Protocols and services
MODBUS_BIND_HOST=127.0.0.1
MODBUS_PORT=1502
HMI_BIND_HOST=127.0.0.1
HMI_PORT=8080
# Deny-by-default: required before binding outside `127.0.0.1`
ALLOW_NONLOCAL_BIND=0
# Explicit runtime mode for controlled internet exposure; normal `docker compose up honeypot`
# now keeps this off and uses the separate `honeypot-exposed` profile instead.
EXPOSED_RESEARCH_ENABLED=0
# Explicit ingress approvals, e.g. `modbus:0.0.0.0:1502,hmi:0.0.0.0:8080`
APPROVED_INGRESS_BINDINGS="" # e.g. modbus:0.0.0.0:1502,hmi:0.0.0.0:8080
# Public ingress mapping, e.g. `modbus:502:1502,hmi:80:8080`
PUBLIC_INGRESS_MAPPINGS="" # e.g. modbus:502:1502,hmi:80:8080
# V1 default: enabled; disable consciously for stricter deployments
ENABLE_SERVICE_LOGIN=1
# Set to 1 only when browsers reach the HMI through HTTPS, e.g. via Caddy.
HMI_COOKIE_SECURE=0
SERVICE_COOKIE_SECURE=0

# Event and storage
EVENT_STORE_BACKEND=sqlite
EVENT_STORE_PATH=./tmp/honeypot-events.db
JSONL_ARCHIVE_ENABLED=1
JSONL_ARCHIVE_PATH=./logs/events.jsonl
RUNTIME_STATUS_ENABLED=0
RUNTIME_STATUS_PATH=./logs/runtime-status.json
RUNTIME_STATUS_INTERVAL_SECONDS=5
PCAP_CAPTURE_ENABLED=0
PCAP_CAPTURE_PATH=./pcap/session.pcapng
ALERT_MIN_SEVERITY=medium
OUTBOX_BATCH_SIZE=50
OUTBOX_RETRY_BACKOFF_SECONDS=30
FINDINGS_LOG_PATH=./logs/findings.md

# Exporters
WEBHOOK_EXPORTER_ENABLED=0
WEBHOOK_EXPORTER_URL="" # e.g. https://collector.example.net/honeypot-ingest
SMTP_EXPORTER_ENABLED=0
SMTP_HOST="" # e.g. mail.example.net
SMTP_PORT=25
SMTP_FROM="" # e.g. honeypot@example.net
SMTP_TO="" # e.g. alerts@example.net
TELEGRAM_EXPORTER_ENABLED=0
TELEGRAM_BOT_TOKEN="" # e.g. 123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID="" # e.g. -1001234567890
# Explicit target approvals, e.g. `webhook:example.invalid:443,smtp:mail.example.invalid:25`
APPROVED_EGRESS_TARGETS="" # e.g. webhook:collector.example.net:443,smtp:mail.example.net:25
# Named export recipients for exposed-research, e.g. `webhook:observer-collector-live`
APPROVED_EGRESS_RECIPIENTS="" # e.g. webhook:observer-collector-live

# Operational assignments for exposed-research
WATCH_OFFICER_NAME="" # e.g. blue-watch
DUTY_ENGINEER_NAME="" # e.g. ops-duty

# Runtime and logging
LOG_LEVEL=info
TREND_WINDOW_MINUTES=180
ALARM_PAGE_SIZE=25
